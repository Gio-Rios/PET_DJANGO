# Copie este arquivo para .env e preencha os valores

# Django
SECRET_KEY=django-insecure-troque-esta-chave-em-producao-!!!
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados (SQLite padrão em dev; use URL do PostgreSQL em produção)
# Desenvolvimento: não precisa definir, usa sqlite:///db.sqlite3
# Produção (Render/Railway): defina a URL completa do PostgreSQL
# DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS (origens permitidas separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
